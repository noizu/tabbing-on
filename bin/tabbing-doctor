#!/bin/sh
# tabbing-doctor — Check terminal config and fix shell integration title conflicts
#
# Detects Ghostty and Kitty configs, checks if their shell integration
# auto-title feature is disabled, and offers to fix it via sed.

set -e

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
_bold()  { printf '\033[1m%s\033[0m' "$1"; }
_green() { printf '\033[32m%s\033[0m' "$1"; }
_yellow(){ printf '\033[33m%s\033[0m' "$1"; }
_red()   { printf '\033[31m%s\033[0m' "$1"; }

_check() { printf '  [%s] %s\n' "$(_green "OK")" "$1"; }
_warn()  { printf '  [%s] %s\n' "$(_yellow "!!")" "$1"; }
_info()  { printf '  [%s] %s\n' "$(_bold "..")" "$1"; }

_ask_yn() {
  printf '%s [y/N] ' "$1"
  read -r ans </dev/tty
  case "$ans" in
    [Yy]*) return 0 ;;
    *) return 1 ;;
  esac
}

# ---------------------------------------------------------------------------
# Terminal detection
# ---------------------------------------------------------------------------
printf '\n%s\n\n' "$(_bold "tabbing-doctor: terminal configuration check")"

printf '%s\n' "$(_bold "Detected terminal:")"
printf '  TAB_TERMINAL = %s\n' "${TAB_TERMINAL:-unknown}"
printf '  TERM         = %s\n' "${TERM:-unset}"
printf '  TERM_FOR_SSHD= %s\n\n' "${TERM_FOR_SSHD:-unset}"

issues=0

# ---------------------------------------------------------------------------
# Ghostty
# ---------------------------------------------------------------------------
ghostty_config_xdg="${XDG_CONFIG_HOME:-$HOME/.config}/ghostty/config"
ghostty_config_macos="$HOME/Library/Application Support/com.mitchellh.ghostty/config"

_is_ghostty=0
case "${TERM:-}" in xterm-ghostty) _is_ghostty=1 ;; esac

printf '%s\n' "$(_bold "Ghostty")"
_ghostty_found=0
for ghostty_config in "$ghostty_config_macos" "$ghostty_config_xdg"; do
  if [ -f "$ghostty_config" ]; then
    _ghostty_found=1
    _info "Config found: $ghostty_config"

    # -- Check 1: static "title" key (locks title, ignores all escape sequences)
    #    Regex anchors on "title" followed by whitespace/= so it won't match
    #    title-report, window-title-font-family, macos-titlebar-style, etc.
    if grep -v '^ *#' "$ghostty_config" | grep -qE '^[[:space:]]*title[[:space:]]*=' 2>/dev/null; then
      _title_val=$(grep -v '^ *#' "$ghostty_config" | grep -E '^[[:space:]]*title[[:space:]]*=' | tail -1 | sed 's/^[^=]*=[[:space:]]*//')
      _warn "\"title = ${_title_val}\" is set — this LOCKS the title and ignores all escape sequences"
      _info "Remove or comment out the 'title' line to allow tabbing to set titles"
      issues=$((issues + 1))
    fi

    # -- Check 2: shell-integration = none + no-title (Ghostty bug #5046)
    #    When shell-integration is "none", shell-integration-features is silently ignored.
    if grep -v '^ *#' "$ghostty_config" | grep -qE '^[[:space:]]*shell-integration[[:space:]]*=[[:space:]]*none' 2>/dev/null; then
      _warn "shell-integration = none — shell-integration-features flags are IGNORED (Ghostty bug #5046)"
      _info "Workaround: export GHOSTTY_SHELL_INTEGRATION_NO_TITLE=1 in your shell rc"
      issues=$((issues + 1))
    fi

    # -- Check 3: shell-integration-features includes no-title
    if grep -v '^ *#' "$ghostty_config" | grep -q 'shell-integration-features' 2>/dev/null; then
      if grep -v '^ *#' "$ghostty_config" | grep -q 'no-title' 2>/dev/null; then
        _check "shell-integration-features includes no-title"
      else
        _warn "shell-integration-features is set but missing no-title"
        issues=$((issues + 1))
        if _ask_yn "  Add no-title to shell-integration-features?"; then
          printf '\n# Added by tabbing-doctor: prevent shell integration from overriding tab titles\nshell-integration-features = cursor,sudo,path,no-title\n' >> "$ghostty_config"
          _check "Appended to $ghostty_config"
        fi
      fi
    else
      _warn "shell-integration-features not set (Ghostty will auto-set tab titles)"
      issues=$((issues + 1))
      if _ask_yn "  Add 'shell-integration-features = cursor,sudo,path,no-title' to config?"; then
        printf '\n# Added by tabbing-doctor: prevent shell integration from overriding tab titles\nshell-integration-features = cursor,sudo,path,no-title\n' >> "$ghostty_config"
        _check "Appended to $ghostty_config"
      fi
    fi
  fi
done
if [ "$_ghostty_found" -eq 0 ]; then
  if [ "$_is_ghostty" -eq 1 ]; then
    case "$(uname -s)" in
      Darwin) ghostty_config="$ghostty_config_macos" ;;
      *)      ghostty_config="$ghostty_config_xdg" ;;
    esac
    _warn "No Ghostty config found (Ghostty will auto-set tab titles)"
    _info "Checked: $ghostty_config_macos"
    _info "Checked: $ghostty_config_xdg"
    issues=$((issues + 1))
    if _ask_yn "  Create config with 'shell-integration-features = cursor,sudo,path,no-title' at $ghostty_config?"; then
      mkdir -p "$(dirname "$ghostty_config")"
      printf '# Added by tabbing-doctor: prevent shell integration from overriding tab titles\nshell-integration-features = cursor,sudo,path,no-title\n' > "$ghostty_config"
      _check "Created $ghostty_config"
    fi
  else
    _info "No Ghostty config found (not running Ghostty, skipped)"
    _info "Checked: $ghostty_config_macos"
    _info "Checked: $ghostty_config_xdg"
  fi
fi

printf '\n'

# ---------------------------------------------------------------------------
# Kitty
# ---------------------------------------------------------------------------
kitty_config="${XDG_CONFIG_HOME:-$HOME/.config}/kitty/kitty.conf"

_is_kitty=0
case "${TERM:-}" in xterm-kitty) _is_kitty=1 ;; esac

printf '%s\n' "$(_bold "Kitty")"
if [ -f "$kitty_config" ]; then
  _info "Config found: $kitty_config"

  if grep -v '^ *#' "$kitty_config" | grep -q 'shell_integration' 2>/dev/null; then
    if grep -v '^ *#' "$kitty_config" | grep -q 'no-title' 2>/dev/null; then
      _check "shell_integration includes no-title"
    else
      _warn "shell_integration is set but missing no-title"
      issues=$((issues + 1))
      if _ask_yn "  Add no-title to shell_integration?"; then
        printf '\n# Added by tabbing-doctor: prevent shell integration from overriding tab titles\nshell_integration no-title\n' >> "$kitty_config"
        _check "Appended to $kitty_config"
      fi
    fi
  else
    _warn "shell_integration not set (Kitty will auto-set tab titles)"
    issues=$((issues + 1))
    if _ask_yn "  Add 'shell_integration no-title' to config?"; then
      printf '\n# Added by tabbing-doctor: prevent shell integration from overriding tab titles\nshell_integration no-title\n' >> "$kitty_config"
      _check "Appended to $kitty_config"
    fi
  fi
elif [ "$_is_kitty" -eq 1 ]; then
  _warn "No config at $kitty_config (Kitty will auto-set tab titles)"
  issues=$((issues + 1))
  if _ask_yn "  Create config with 'shell_integration no-title'?"; then
    mkdir -p "$(dirname "$kitty_config")"
    printf '# Added by tabbing-doctor: prevent shell integration from overriding tab titles\nshell_integration no-title\n' > "$kitty_config"
    _check "Created $kitty_config"
  fi
else
  _info "No config at $kitty_config (not running Kitty, skipped)"
fi

printf '\n'

# ---------------------------------------------------------------------------
# SSH / TERM_FOR_SSHD
# ---------------------------------------------------------------------------
printf '%s\n' "$(_bold "SSH")"
if [ -n "${TERM_FOR_SSHD:-}" ]; then
  _check "TERM_FOR_SSHD is set ($TERM_FOR_SSHD)"
  # Detect ssh wrapper in shell rc files (can't use `type` — we run under /bin/sh)
  _ssh_wrapper_found=0
  for _rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
    if [ -f "$_rc" ] && grep -v '^ *#' "$_rc" | grep -qE '(ssh\s*\(\)|function ssh)' 2>/dev/null; then
      _ssh_wrapper_found=1
      break
    fi
  done
  if [ "$_ssh_wrapper_found" -eq 1 ]; then
    _check "ssh wrapper function detected in $_rc (TERM override active)"
  else
    _warn "No ssh wrapper — remote hosts will get TERM=$TERM"
    _info "Add to .zshrc: ssh() { TERM=\"\$TERM_FOR_SSHD\" command ssh \"\$@\"; }"
    issues=$((issues + 1))
  fi
else
  case "${TERM:-}" in
    xterm-ghostty|xterm-kitty)
      _warn "TERM=$TERM but TERM_FOR_SSHD not set — remote hosts may have issues"
      _info "Add to .zshrc:"
      _info "  case \"\$TERM\" in xterm-ghostty|xterm-kitty) TERM_FOR_SSHD=xterm-256color ;; *) TERM_FOR_SSHD=\$TERM ;; esac"
      _info "  ssh() { TERM=\"\$TERM_FOR_SSHD\" command ssh \"\$@\"; }"
      issues=$((issues + 1))
      ;;
    *)
      _check "TERM=$TERM (no override needed for SSH)"
      ;;
  esac
fi

printf '\n'

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
if [ "$issues" -eq 0 ]; then
  printf '%s\n\n' "$(_green "All checks passed. Tab titles should work correctly.")"
else
  printf '%s\n\n' "$(_yellow "$issues issue(s) found. Restart your terminal after making changes.")"
fi
