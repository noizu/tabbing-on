#!/usr/bin/env bash
# bin/_tabbing-commit — Side-effects helper for thin adapter
#
# Called by the shell adapter functions when full libs are not loaded.
# Inherits exported TAB_* env vars from the parent shell.
# Does NOT call _tabbing_session_load (would overwrite fresh values).
#
# Usage: _tabbing-commit <event_type>
#   event_type: title, status, todo_add, todo_switch, todo_done, etc.

TABBING_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Source libs needed for side effects (render.sh is also needed for display)
for _lib in render core terminal history session; do
  . "$TABBING_ROOT/lib/${_lib}.sh"
done

_tabbing_ensure_tab_id
_tabbing_record_event "${1:-status}"
_tabbing_display
_tabbing_session_save
