#!/usr/bin/env bash
# bin/tabbing-recordings — list/manage recordings CLI
source "$(dirname "${BASH_SOURCE[0]}")/_tabbing-wrapper"

target_tab="${TAB_ID:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tab)    target_tab="$2"; shift 2 ;;
    --tab=*)  target_tab="${1#--tab=}"; shift ;;
    --to-gif)
      if [[ -n "${2:-}" ]]; then
        _tabbing_recording_to_gif "$2" "${3:-}"
        exit
      else
        echo "tabbing-recordings: --to-gif requires a .cast file path" >&2
        exit 1
      fi
      ;;
    *) shift ;;
  esac
done

_tabbing_recordings_list "$target_tab"
