#!/usr/bin/env bash
# bin/tabbing-todo — todo management CLI
#
# Handles all todo operations directly using lib functions.
# Also supports internal flags for the thin adapter:
#   --list-pending    Output pending todos (id title per line)
#   --export-switch   Do file mutation, output export statements

source "$(dirname "${BASH_SOURCE[0]}")/_tabbing-wrapper"

# Internal flags (used by adapter, short-circuit before arg parsing)
case "${1:-}" in
  --list-pending)
    _tabbing_ensure_tab_id
    _tabbing_todo_pending
    exit
    ;;
  --export-switch)
    shift
    _export_id="$1"
    if [ -z "$_export_id" ]; then
      echo "tabbing-todo: --export-switch requires a todo ID" >&2
      exit 1
    fi

    _tabbing_ensure_tab_id
    _tabbing_todo_init_file

    _tfile="$(_tabbing_todo_file)"
    if [ ! -f "$_tfile" ]; then
      echo "tabbing: no todos found" >&2
      exit 1
    fi

    # Deactivate current active, activate target
    _tmpfile="${_tfile}.tmp"
    awk -v target="$_export_id" '
      /^  - id:/ { id = $3 }
      /^    status:/ {
        s = $0
        sub(/^    status: "/, "", s)
        sub(/"$/, "", s)
        if (s == "active") { print "    status: \"pending\""; next }
        if (id == target && s == "pending") { print "    status: \"active\""; next }
      }
      { print }
    ' "$_tfile" > "$_tmpfile"
    mv "$_tmpfile" "$_tfile"

    # Get todo details and output export statements
    _todo_info="$(_tabbing_todo_get "$_export_id")"
    eval "$_todo_info"

    if [ -n "${TODO_TITLE:-}" ]; then
      printf 'export TAB_STATUS="%s"\n' "$(printf '%s' "$TODO_TITLE" | sed 's/"/\\"/g')"
    fi
    if [ -n "${TODO_EMOJI:-}" ]; then
      printf 'export TAB_EMOJI="%s"\n' "$(printf '%s' "$TODO_EMOJI" | sed 's/"/\\"/g')"
    fi
    if [ -n "${TODO_URGENCY:-}" ]; then
      printf 'export TAB_URGENCY="%s"\n' "$TODO_URGENCY"
    fi

    _tabbing_record_event "todo_switch"
    printf 'tabbing: switched to todo #%s: %s\n' "$_export_id" "${TODO_TITLE:-}" >&2
    exit
    ;;
esac

# Full arg parsing for direct CLI usage
opt_desc="" opt_emoji="" opt_urgency=""
has_desc=0 has_emoji=0 has_urgency=0
has_record=0 has_continue=0 has_stop_recording=0
do_switch=0 do_done=0 done_id=""
positional=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m|--message)     opt_desc="$2"; has_desc=1; shift 2 ;;
    -m=*|--message=*) opt_desc="${1#*=}"; has_desc=1; shift ;;

    --emoji=*)   opt_emoji="${1#--emoji=}"; has_emoji=1; shift ;;
    --emoji)     opt_emoji="$2"; has_emoji=1; shift 2 ;;
    -e)          opt_emoji="$2"; has_emoji=1; shift 2 ;;

    --urgency=*) opt_urgency="${1#--urgency=}"; has_urgency=1; shift ;;
    --urgency)   opt_urgency="$2"; has_urgency=1; shift 2 ;;
    --pri=*)     opt_urgency="${1#--pri=}"; has_urgency=1; shift ;;
    --pri)       opt_urgency="$2"; has_urgency=1; shift 2 ;;
    -p)          opt_urgency="$2"; has_urgency=1; shift 2 ;;
    -pri[0-5])   opt_urgency="${1#-pri}"; has_urgency=1; shift ;;

    -n|--switch|--pick) do_switch=1; shift ;;
    --done)
      do_done=1
      if [[ -n "${2:-}" && "$2" =~ ^[0-9]+$ ]]; then
        done_id="$2"; shift 2
      else
        shift
      fi
      ;;

    --record)         has_record=1; shift ;;
    --continue)       has_continue=1; shift ;;
    --stop-recording) has_stop_recording=1; shift ;;

    -[a-z]*)
      maybe="${1#-}"
      if [[ "$maybe" =~ ^pri[0-5]$ ]]; then
        opt_urgency="${maybe#pri}"; has_urgency=1; shift
      elif _tabbing_is_known_emoji "$maybe"; then
        opt_emoji="$maybe"; has_emoji=1; shift
      else
        positional+=("$1"); shift
      fi
      ;;

    *) positional+=("$1"); shift ;;
  esac
done

if [[ -z "$TAB_TITLE" ]]; then
  echo "tabbing-todo: no TAB_TITLE set — call tabbing-on first" >&2
  exit 1
fi

_tabbing_ensure_tab_id

# Handle --done
if [[ $do_done -eq 1 ]]; then
  _tabbing_todo_done "$done_id"
  exit
fi

# Handle --switch / -n (interactive)
if [[ $do_switch -eq 1 ]]; then
  _tabbing_todo_switch_interactive() {
    local pending
    pending="$(_tabbing_todo_pending)"
    if [[ -z "$pending" ]]; then
      echo "tabbing: no pending todos to switch to" >&2
      return 1
    fi

    echo "Pending todos:"
    local ids=() titles=()
    while IFS=' ' read -r id title; do
      ids+=("$id")
      titles+=("$title")
      printf '  %s) %s\n' "$id" "$title"
    done <<< "$pending"

    printf '\nSwitch to todo #: '
    local choice
    read -r choice

    local valid=0
    for id in "${ids[@]}"; do
      if [[ "$choice" == "$id" ]]; then
        valid=1; break
      fi
    done

    if [[ $valid -eq 0 ]]; then
      echo "tabbing: invalid choice" >&2
      return 1
    fi

    _tabbing_todo_switch "$choice"
  }
  _tabbing_todo_switch_interactive

  if [[ $has_record -eq 1 || $has_continue -eq 1 || $has_stop_recording -eq 1 ]]; then
    _tabbing_handle_recording "$has_record" "$has_continue" "$has_stop_recording"
  fi
  exit
fi

# No positional args — list todos
if [[ ${#positional[@]} -eq 0 ]]; then
  _tabbing_todo_list
  exit
fi

# Add a new todo
title="${positional[0]}"
_tabbing_todo_add "$title" "$opt_desc" "$opt_emoji" "$opt_urgency"

if [[ $has_record -eq 1 || $has_continue -eq 1 || $has_stop_recording -eq 1 ]]; then
  _tabbing_handle_recording "$has_record" "$has_continue" "$has_stop_recording"
fi
