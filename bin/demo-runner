#!/usr/bin/env zsh
# demo-runner — Typewriter-style demo runner for tabbing-on
#
# Reads a .demo script and plays it back:
#   # lines  → bold colored headings (appear instantly)
#   ## lines → dim descriptions (appear instantly)
#   $ lines  → typed out char-by-char, then executed
#   @ sleep N → pause N seconds
#   @input TEXT → simulate typing input to the previous command's stdin
#   @prompt TEXT → pause and wait for user to press Enter (shows TEXT)
#   blank lines → printed as-is
#
# Usage:
#   bin/demo-runner [script.demo]   # default: demo/showcase.demo
#   bin/demo-runner --speed fast    # fast/medium/slow
#   bin/demo-runner --no-pause      # skip inter-command pauses

set -e

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
_DEMO_SPEED="${TABBING_DEMO_SPEED:-medium}"
_DEMO_PAUSE=1        # pause between commands
_DEMO_HEADING_PAUSE=1 # pause after headings
_DEMO_SCRIPT=""
_DEMO_NO_PAUSE=0

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --speed)    _DEMO_SPEED="$2"; shift 2 ;;
    --speed=*)  _DEMO_SPEED="${1#--speed=}"; shift ;;
    --fast)     _DEMO_SPEED="fast"; shift ;;
    --slow)     _DEMO_SPEED="slow"; shift ;;
    --no-pause) _DEMO_NO_PAUSE=1; shift ;;
    --help|-h)
      printf 'demo-runner — Typewriter-style demo runner\n\n'
      printf 'Usage: bin/demo-runner [options] [script.demo]\n\n'
      printf 'Options:\n'
      printf '  --speed fast|medium|slow   Typing speed (default: medium)\n'
      printf '  --fast                     Shorthand for --speed fast\n'
      printf '  --slow                     Shorthand for --speed slow\n'
      printf '  --no-pause                 Skip inter-command pauses\n'
      exit 0
      ;;
    *)
      _DEMO_SCRIPT="$1"; shift ;;
  esac
done

# Speed → character delay (seconds)
case "$_DEMO_SPEED" in
  fast)   _CHAR_DELAY=0.01; _DEMO_PAUSE=0.5; _DEMO_HEADING_PAUSE=0.5 ;;
  medium) _CHAR_DELAY=0.03; _DEMO_PAUSE=1.0; _DEMO_HEADING_PAUSE=1.0 ;;
  slow)   _CHAR_DELAY=0.06; _DEMO_PAUSE=1.5; _DEMO_HEADING_PAUSE=1.5 ;;
  *)      _CHAR_DELAY=0.03; _DEMO_PAUSE=1.0; _DEMO_HEADING_PAUSE=1.0 ;;
esac

if [[ $_DEMO_NO_PAUSE -eq 1 ]]; then
  _DEMO_PAUSE=0.2
  _DEMO_HEADING_PAUSE=0.3
fi

# Find the demo script
_DEMO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -z "$_DEMO_SCRIPT" ]]; then
  _DEMO_SCRIPT="${_DEMO_ROOT}/demo/showcase.demo"
fi
if [[ ! -f "$_DEMO_SCRIPT" ]]; then
  printf 'demo-runner: script not found: %s\n' "$_DEMO_SCRIPT" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# ANSI helpers
# ---------------------------------------------------------------------------
_RST=$'\033[0m'
_BOLD=$'\033[1m'
_DIM=$'\033[2m'
_GREEN=$'\033[32m'
_CYAN=$'\033[36m'
_YELLOW=$'\033[33m'
_GRAY=$'\033[90m'

# ---------------------------------------------------------------------------
# Typewriter: print string char-by-char with delay
# ---------------------------------------------------------------------------
_typewrite() {
  local text="$1"
  local i=0
  while [[ $i -lt ${#text} ]]; do
    printf '%s' "${text:$i:1}"
    # Vary delay slightly for natural feel
    if (( RANDOM % 3 == 0 )); then
      sleep "$(printf '%.3f' "$(echo "$_CHAR_DELAY * 2" | bc)")"
    else
      sleep "$_CHAR_DELAY"
    fi
    i=$((i + 1))
  done
}

# ---------------------------------------------------------------------------
# Display a prompt, type the command, then execute it
# ---------------------------------------------------------------------------
_run_command() {
  local cmd="$1"

  # Show the prompt
  printf '%s%s$%s ' "$_BOLD" "$_GREEN" "$_RST"

  # Type out the command
  _typewrite "$cmd"

  # Hit "enter"
  printf '\n'

  # Brief pause before output (like a real terminal)
  sleep 0.1

  # Execute the command in the current shell context
  eval "$cmd"

  # Pause after command
  sleep "$_DEMO_PAUSE"
}

# ---------------------------------------------------------------------------
# Display a heading
# ---------------------------------------------------------------------------
_show_heading() {
  local text="$1"
  printf '\n%s%s%s%s\n' "$_BOLD" "$_CYAN" "$text" "$_RST"
  printf '%s%s%s\n' "$_CYAN" "$(printf '%.0s─' {1..${#text}})" "$_RST"
  sleep "$_DEMO_HEADING_PAUSE"
}

# ---------------------------------------------------------------------------
# Display a description
# ---------------------------------------------------------------------------
_show_desc() {
  local text="$1"
  printf '%s%s%s\n' "$_DIM" "$text" "$_RST"
}

# ---------------------------------------------------------------------------
# Source tabbing-on so commands work in this shell
# ---------------------------------------------------------------------------
source "${_DEMO_ROOT}/shell/tabbing.zsh"

# Clear any prior state and data
unset TAB_TITLE TAB_STATUS TAB_URGENCY TAB_EMOJI TAB_HIGHLIGHT TAB_ID TAB_RECORDING
rm -rf "${XDG_STATE_HOME:-$HOME/.local/state}/tabbing" 2>/dev/null

# ---------------------------------------------------------------------------
# Demo helpers (available inside .demo scripts)
# ---------------------------------------------------------------------------

# Create a sample .cast recording file for demo purposes
# (So we can show tabbing-recordings and asciinema play without
# actually entering an asciinema sub-shell during the demo)
_tabbing_demo_create_sample_cast() {
  _tabbing_ensure_tab_id
  local rec_dir
  rec_dir="$(_tabbing_state_dir)/recordings/${TAB_ID}"
  mkdir -p "$rec_dir"
  local ts
  ts="$(date +%Y%m%dT%H%M%S)"
  local status_slug
  status_slug="$(printf '%s' "${TAB_STATUS:-demo}" | tr ' /' '-_' | tr -cd 'a-zA-Z0-9_-')"
  local cast_file="${rec_dir}/${ts}_${status_slug}.cast"

  # Write a minimal valid asciicast v2 file
  cat > "$cast_file" << 'CAST'
{"version": 2, "width": 80, "height": 24, "timestamp": 1709500000, "env": {"SHELL": "/bin/zsh", "TERM": "xterm-256color"}}
[0.0, "o", "\u001b[32m$\u001b[0m "]
[0.3, "o", "t"]
[0.35, "o", "a"]
[0.4, "o", "b"]
[0.45, "o", "b"]
[0.5, "o", "i"]
[0.55, "o", "n"]
[0.6, "o", "g"]
[0.65, "o", "-"]
[0.7, "o", "o"]
[0.75, "o", "n"]
[0.8, "o", " "]
[0.85, "o", "\""]
[0.9, "o", "A"]
[0.95, "o", "c"]
[1.0, "o", "m"]
[1.05, "o", "e"]
[1.1, "o", "\""]
[1.15, "o", " "]
[1.2, "o", "-"]
[1.25, "o", "r"]
[1.3, "o", "o"]
[1.35, "o", "c"]
[1.4, "o", "k"]
[1.45, "o", "e"]
[1.5, "o", "t"]
[1.6, "o", "\r\n"]
[1.8, "o", "\u001b[32m$\u001b[0m "]
[2.1, "o", "e"]
[2.15, "o", "c"]
[2.2, "o", "h"]
[2.25, "o", "o"]
[2.3, "o", " "]
[2.35, "o", "\""]
[2.4, "o", "B"]
[2.45, "o", "u"]
[2.5, "o", "i"]
[2.55, "o", "l"]
[2.6, "o", "d"]
[2.65, "o", "i"]
[2.7, "o", "n"]
[2.75, "o", "g"]
[2.8, "o", "."]
[2.85, "o", "."]
[2.9, "o", "."]
[2.95, "o", "\""]
[3.0, "o", "\r\n"]
[3.1, "o", "Building...\r\n"]
[3.3, "o", "\u001b[32m$\u001b[0m "]
[3.6, "o", "echo \"Tests passing \u2705\"\r\n"]
[3.7, "o", "Tests passing \u2705\r\n"]
[3.9, "o", "\u001b[32m$\u001b[0m "]
[4.2, "o", "echo \"Done!\"\r\n"]
[4.3, "o", "Done!\r\n"]
[4.5, "o", "\u001b[32m$\u001b[0m "]
CAST

  export TAB_RECORDING="$cast_file"
  _tabbing_record_event "record_start"
  _tabbing_record_event "record_stop"
  unset TAB_RECORDING
  printf 'tabbing: sample recording created: %s\n' "$cast_file"
}

# Find first .cast file for current tab and play it
_tabbing_demo_play_recording() {
  local rec_dir
  rec_dir="$(_tabbing_state_dir)/recordings/${TAB_ID}"
  local cast_file=""
  for f in "$rec_dir"/*.cast; do
    [ -f "$f" ] || continue
    cast_file="$f"
    break
  done
  if [ -z "$cast_file" ]; then
    printf 'tabbing: no recordings to play\n'
    return 1
  fi
  if ! command -v asciinema >/dev/null 2>&1; then
    printf 'tabbing: asciinema not installed — showing raw cast header instead:\n'
    head -1 "$cast_file"
    printf '\n(install asciinema to play recordings)\n'
    return 0
  fi
  printf 'tabbing: playing %s\n\n' "$(basename "$cast_file")"
  asciinema play --speed 2 "$cast_file" || {
    printf '\n(asciinema play requires an interactive terminal)\n'
    printf '(in your real terminal: asciinema play %s)\n' "$cast_file"
  }
}

# ---------------------------------------------------------------------------
# Play the script
# ---------------------------------------------------------------------------
while IFS= read -r line || [[ -n "$line" ]]; do
  case "$line" in
    '## '*)
      # Description line
      _show_desc "${line#\#\# }"
      ;;
    '# '*)
      # Heading line
      _show_heading "${line#\# }"
      ;;
    '$ '*)
      # Command to type and execute
      _run_command "${line#\$ }"
      ;;
    '@sleep '*)
      # Explicit pause
      local secs="${line#@sleep }"
      sleep "$secs"
      ;;
    '@input '*)
      # This is handled by piping into the previous command
      # For now, just display it as typed input
      local input_text="${line#@input }"
      _typewrite "$input_text"
      printf '\n'
      ;;
    '@prompt'|'@prompt '*)
      # Pause and wait for user input
      # TODO: future — add section jump selection menu here
      local prompt_text="${line#@prompt}"
      prompt_text="${prompt_text# }"  # strip leading space
      if [[ -z "$prompt_text" ]]; then
        prompt_text="Press Enter to continue..."
      fi
      printf '\n%s%s%s ' "$_YELLOW" "$prompt_text" "$_RST"
      read -r < /dev/tty
      ;;
    '@clear')
      clear
      ;;
    '')
      printf '\n'
      ;;
    *)
      # Anything else, just print it
      printf '%s\n' "$line"
      ;;
  esac
done < "$_DEMO_SCRIPT"

# Final
printf '\n%s%sDone!%s\n' "$_BOLD" "$_GREEN" "$_RST"
