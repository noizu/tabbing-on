[0.050, "o", "\r\n\u001b[1m\u001b[36mtabbing-on\u001b[0m\r\n"]
[0.001, "o", "\u001b[36m──────────\u001b[0m\r\n"]
[1.007, "o", "\r\n"]
[0.000, "o", "\u001b[2mA terminal tab title, status & task manager.\u001b[0m\r\n"]
[0.001, "o", "\u001b[2mWorks with Ghostty, iTerm2, Kitty, WezTerm, Alacritty, and more.\u001b[0m\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1m\u001b[32m$\u001b[0m "]
[0.000, "o", "t"]
[0.039, "o", "a"]
[0.037, "o", "b"]
[0.038, "o", "b"]
[0.035, "o", "i"]
[0.073, "o", "n"]
[0.072, "o", "g"]
[0.039, "o", "-"]
[0.040, "o", "o"]
[0.041, "o", "n"]
[0.036, "o", " "]
[0.039, "o", "h"]
[0.039, "o", "e"]
[0.036, "o", "l"]
[0.038, "o", "p"]
[0.038, "o", "\r\n"]
[0.111, "o", "tabbing-on — Terminal tab title, status & task manager\r\n\r\nUsage:\r\n  tabbing-on [flags] \"title\" \"status\"    Set tab title and status\r\n  tabbing-on                             Show current state\r\n  tabbing-on emojis                      List available emojis\r\n  tabbing-on colors                      List available colors\r\n"]
[0.000, "o", "  tabbing-on help                        Show this help\r\n\r\nFlags:\r\n  --highlight COLOR, -h COLOR, -COLOR    Set title highlight color\r\n  --urgency N, --pri N, -p N, -priN      Set urgency 0-5 (0=critical)\r\n"]
[0.000, "o", "  --emoji NAME, -e NAME, -NAME           Set emoji indicator\r\n  --no-emoji                             Clear emoji\r\n"]
[0.000, "o", "  --record                               Start asciinema recording\r\n  --continue                             Keep recording across status change\r\n  --stop-recording                       Stop recording\r\n"]
[0.000, "o", "  --terminal-info                        Show detected terminal\r\n\r\nRelated commands:\r\n"]
[0.000, "o", "  tabbing-status [flags] \"text\"           Update status only\r\n  tabbing-todo \"title\" [-m \"desc\"]        Add todo item\r\n  tabbing-todo                            List todos\r\n  tabbing-todo --pick                     Switch to a todo interactively\r\n  tabbing-todo --done [id]                Mark todo done\r\n"]
[0.000, "o", "  tabbing-report [--mermaid] [--all]      Time-in-state report\r\n  tabbing-history [query]                 Search/browse history\r\n"]
[0.000, "o", "  tabbing-info                             Full tab info (state, paths, recordings)\r\n"]
[0.000, "o", "  tabbing-recordings                      List recordings\r\n  tabbing-clear history|todos|recordings   Clear data\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "Examples:\r\n"]
[0.000, "o", "  tabbing-on -rocket -blue \"MyApp\" \"deploying\" -p 2\r\n  tabbing-status -fire \"hotfix\"\r\n  tabbing-todo \"Write tests\" -e test -m \"Cover edge cases\"\r\n"]
[0.000, "o", "\r\n"]
[1.008, "o", "\r\n"]
