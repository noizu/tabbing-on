[0.767, "o", "\u001b[39m-\u001b[39mr\u001b[39mu\u001b[39mn\u001b[39mn\u001b[39me\u001b[39mr\u001b[39m \u001b[39m.\u001b[39m/\u001b[39md\u001b[39me\u001b[39mm\u001b[39mo\u001b[39m/\u001b[39ms\u001b[39mh\u001b[39mo\u001b[39mw\u001b[39mc\u001b[39ma\u001b[39ms\u001b[39me\u001b[39m.\u001b[39md\u001b[39me\u001b[39mm\u001b[39mo"]
[0.002, "o", "\u001b[32D\u001b[24m\u001b[32md\u001b[24m\u001b[32me\u001b[24m\u001b[32mm\u001b[24m\u001b[32mo\u001b[32m-\u001b[32mr\u001b[32mu\u001b[32mn\u001b[32mn\u001b[32me\u001b[32mr\u001b[39m \u001b[4m.\u001b[4m/\u001b[4md\u001b[4me\u001b[4mm\u001b[4mo\u001b[4m/\u001b[4ms\u001b[4mh\u001b[4mo\u001b[4mw\u001b[4mc\u001b[4ma\u001b[4ms\u001b[4me\u001b[4m.\u001b[4md\u001b[4me\u001b[4mm\u001b[4mo\u001b[24m"]
